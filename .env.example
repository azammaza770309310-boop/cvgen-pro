# CVGen Pro environment variables (copy to .env)
# API keys are server-side only and NEVER exposed to the frontend.

# Primary provider
GEMINI_API_KEY=
# Optional comma-separated backup keys for rotation
GEMINI_BACKUP_KEYS=

# Optional cloud AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=

# Provider selection
DEFAULT_AI_PROVIDER=gemini
BACKUP_AI_PROVIDER=openrouter

# Application
DEBUG=false
PORT=3000
